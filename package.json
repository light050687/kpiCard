{
  "name": "superset-plugin-chart-kpi-card",
  "version": "0.1.0",
  "description": "KPI Card visualization plugin for Apache Superset 6.0+ with plan/YoY comparisons, abs/pct toggle, and design system v2.0 theming",
  "sideEffects": false,
  "main": "src/index.ts",
  "module": "src/index.ts",
  "files": [
    "esm",
    "lib"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [
    "superset",
    "chart",
    "kpi",
    "big-number"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "build": "npm run build-cjs && npm run build-esm",
    "build-cjs": "tsc --outDir lib --module commonjs",
    "build-esm": "tsc --outDir esm --module esnext",
    "dev": "tsc --watch --outDir esm --module esnext",
    "storybook": "storybook dev -p 6012",
    "build-storybook": "storybook build",
    "test": "jest"
  },
  "peerDependencies": {
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@superset-ui/chart-controls": "*",
    "@superset-ui/core": "*",
    "react": "^17.0.2 || ^18.0.0",
    "react-dom": "^17.0.2 || ^18.0.0"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-webpack5-compiler-swc": "^1.0.5",
    "@storybook/react": "^8.6.14",
    "@storybook/react-webpack5": "^8.6.14",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.0.0",
    "storybook": "^8.6.14",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0"
  }
}
